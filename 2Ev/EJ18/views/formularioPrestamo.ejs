<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Nuevo Préstamo</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

<h1>Prestar Libro</h1>

<h2><%= libro.titulo %></h2>

<form action="/prestamo/nuevo" method="POST">

    <input type="hidden" name="libro_id" value="<%= libro.id %>">

    <label>Nombre prestatario</label>
    <input type="text" name="nombre_prestatario" required>

    <label>Fecha préstamo</label>
    <input type="date" name="fecha_prestamo" required>

    <label>Fecha devolución</label>
    <input type="date" name="fecha_devolucion" required>

    <button type="submit">Confirmar préstamo</button>

</form>

</body>
</html>