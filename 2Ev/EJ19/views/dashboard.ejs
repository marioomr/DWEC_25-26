<%- include('partials/header') %>

<h1>Dashboard</h1>

<h2>Editar Perfil</h2>

<form action="/update-profile" method="POST">

  <textarea name="bio" placeholder="Biografía"><%= user.bio || '' %></textarea>

  <input 
    type="email" 
    name="email" 
    value="<%= user.email || '' %>"
  >

  <button type="submit">Guardar</button>

</form>

<hr>

<h2>Enlaces Sociales</h2>

<form action="/add-social" method="POST">

  <input 
    type="text" 
    name="platform" 
    placeholder="GitHub"
    required
  >

  <input 
    type="text" 
    name="url" 
    placeholder="https://..."
    required
  >

  <button type="submit">Agregar</button>

</form>

<ul>

  <% links.forEach(link => { %>

    <li>

      <strong><%= link.platform %></strong>

      -

      <a href="<%= link.url %>">
        <%= link.url %>
      </a>

      |

      <a href="/delete-social/<%= link.id %>">
        Eliminar
      </a>

    </li>

  <% }) %>

</ul>

<hr>

<h2>Proyectos</h2>

<form action="/add-project" method="POST">

  <input 
    type="text" 
    name="title" 
    placeholder="Título"
    required
  >

  <textarea 
    name="description" 
    placeholder="Descripción"
  ></textarea>

  <input 
    type="text" 
    name="repo_url" 
    placeholder="Repositorio GitHub"
  >

  <input 
    type="text" 
    name="live_url" 
    placeholder="Demo en vivo"
  >

  <button type="submit">
    Agregar Proyecto
  </button>

</form>

<ul>

  <% projects.forEach(project => { %>

    <li>

      <h3><%= project.title %></h3>

      <p><%= project.description %></p>

      <a href="<%= project.repo_url %>">
        Repositorio
      </a>

      |

      <a href="<%= project.live_url %>">
        Demo
      </a>

      |

      <a href="/edit-project/<%= project.id %>">
        Editar
      </a>

      |

      <a href="/delete-project/<%= project.id %>">
        Eliminar
      </a>

    </li>

  <% }) %>

</ul>

<%- include('partials/footer') %>